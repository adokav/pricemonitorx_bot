# --- ZORUNLU ---
TELEGRAM_TOKEN=

# --- OPSİYONEL (varsayılanlar) ---
# Watchlist'i boş kullanıcılar için hacme göre ilk N coin (0 = dinamik mod kapalı)
DYNAMIC_TOP_N=150
# Dinamik evrenden hariç tutulacak tabanlar (ör. PEPE,SHIB)
EXCLUDE_BASES=
# DYNAMIC_TOP_N=0 ise taranacak sabit liste
DEFAULT_SYMBOLS=BTC,ETH,SOL
# İşlem çifti karşılığı
QUOTE_ASSET=USDT
# Yeni sinyal (giriş) eşiği
ALERT_SCORE_THRESHOLD=0.40
# Formasyon bozuldu (çıkış) eşiği — histerezis
SIGNAL_EXIT_THRESHOLD=0.20
# Periyodik tarama sıklığı (dakika)
SCAN_INTERVAL_MIN=15
# SQLite dosya yolu
DB_PATH=crypto_signals.db
# Tanımlıysa health endpoint açılır (Render Web Service)
# PORT=10000
