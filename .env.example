# --- ZORUNLU ---
TELEGRAM_TOKEN=

# --- OPSİYONEL (varsayılanlar) ---
# /start'ta otomatik kurulan çekirdek takip listesi (sonra /ekle /sil ile düzenlenir)
DEFAULT_SYMBOLS=BTC,ETH,SOL,AVAX,LINK,ONDO,WLD,RENDER,LDO,POPCAT,WIF
# /check taramasında bakılacak coin sayısı (hacme göre ilk N)
CHECK_TOP_N=100
# /check'te bir coin'in radara aday olması için gereken skor eşiği
CHECK_SCORE_THRESHOLD=0.50
# /check evreninden hariç tutulacak tabanlar (ör. PEPE,SHIB)
EXCLUDE_BASES=
# İşlem çifti karşılığı
QUOTE_ASSET=USDT
# Yeni sinyal (giriş) eşiği
ALERT_SCORE_THRESHOLD=0.40
# Formasyon bozuldu (çıkış) eşiği — histerezis
SIGNAL_EXIT_THRESHOLD=0.20
# Periyodik tarama sıklığı (dakika)
SCAN_INTERVAL_MIN=15
# Vadeli/Spot farkı (futures baz) sinyali — futures API engelliyse otomatik atlanır
ENABLE_FUTURES_BASIS=true
# Kalıcı veri için PostgreSQL bağlantısı (tanımlıysa SQLite yerine kullanılır).
# Render/Neon/Supabase'in verdiği "postgresql://..." adresini buraya koy.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# SQLite dosya yolu (DATABASE_URL yoksa kullanılır — Render'da ephemeral!)
DB_PATH=crypto_signals.db
# Tanımlıysa health endpoint açılır (Render Web Service)
# PORT=10000
